# ─── Authentication ───────────────────────────────────────
# Login credentials for the UI gate (server-only, not exposed to client)
AUTH_USERNAME=
AUTH_PASSWORD=

# ─── Application Mode ────────────────────────────────────
# Options: mock | sandbox
# - mock: Uses synthetic data, no external API calls
# - sandbox: Uses Optum sandbox API with test credentials
# Runtime toggle in the UI overrides this default.
NEXT_PUBLIC_APP_ENV=mock

# ─── Optum API — Sandbox Credentials ─────────────────────
# Client ID issued by Optum developer portal
OPTUM_CLIENT_ID=
# Client Secret issued by Optum developer portal
OPTUM_CLIENT_SECRET=
# OAuth2 token endpoint for Optum API authentication
OPTUM_AUTH_URL=
# Optum GraphQL API endpoint (eligibility sandbox)
OPTUM_ELIGIBILITY_URL=
# Provider Tax ID for Optum API headers (optional)
OPTUM_PROVIDER_TAX_ID=

# ─── Anthropic Claude API ────────────────────────────────
# API key from console.anthropic.com for AI-powered claim analysis
ANTHROPIC_API_KEY=
